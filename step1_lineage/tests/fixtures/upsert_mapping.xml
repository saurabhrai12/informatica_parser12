<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="CUST_DIM_UPSERT">
        <SOURCE NAME="CUSTOMER_DELTA_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="CUST_ID"       DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_NAME"     DATATYPE="varchar2" LENGTH="100" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="EMAIL"         DATATYPE="varchar2" LENGTH="200"/>
          <SOURCEFIELD NAME="PHONE"         DATATYPE="varchar2" LENGTH="20"/>
          <SOURCEFIELD NAME="SEGMENT_CD"    DATATYPE="varchar2" LENGTH="5"/>
          <SOURCEFIELD NAME="KYC_STATUS"    DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="LAST_MOD_DT"   DATATYPE="date"/>
          <SOURCEFIELD NAME="CREATED_DT"    DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="CUSTOMER_DIM" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="CUST_ID"       DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="CUST_NAME"     DATATYPE="varchar2" LENGTH="100" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="EMAIL"         DATATYPE="varchar2" LENGTH="200"/>
          <TARGETFIELD NAME="PHONE"         DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="SEGMENT_CD"    DATATYPE="varchar2" LENGTH="5"/>
          <TARGETFIELD NAME="KYC_STATUS"    DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="LAST_MOD_DT"   DATATYPE="date"/>
          <TARGETFIELD NAME="CREATED_DT"    DATATYPE="date"/>
          <TARGETFIELD NAME="LOAD_TS"       DATATYPE="date"/>
          <TARGETFIELD NAME="BATCH_ID"      DATATYPE="varchar2" LENGTH="50"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_CUST_DELTA" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="CUST_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_NAME"   DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="EMAIL"       DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="PHONE"       DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="SEGMENT_CD"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="KYC_STATUS"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="LAST_MOD_DT" DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CREATED_DT"  DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT * FROM CUSTOMER_DELTA_SRC WHERE LAST_MOD_DT &gt;= $$WATERMARK_FROM"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_CUST" TYPE="Expression">
          <TRANSFORMFIELD NAME="CUST_ID"     DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"/>
          <TRANSFORMFIELD NAME="CUST_NAME"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="UPPER(LTRIM(RTRIM(CUST_NAME)))"/>
          <TRANSFORMFIELD NAME="EMAIL"       DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="LOWER(NVL(EMAIL,'NO_EMAIL'))"/>
          <TRANSFORMFIELD NAME="PHONE"       DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="LTRIM(RTRIM(NVL(PHONE,'N/A')))"/>
          <TRANSFORMFIELD NAME="SEGMENT_CD"  DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(SEGMENT_CD,'GEN')"/>
          <TRANSFORMFIELD NAME="KYC_STATUS"  DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="KYC_STATUS"/>
          <TRANSFORMFIELD NAME="LAST_MOD_DT" DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="LAST_MOD_DT"/>
          <TRANSFORMFIELD NAME="CREATED_DT"  DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="CREATED_DT"/>
          <TRANSFORMFIELD NAME="LOAD_TS"     DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="SYSDATE"/>
          <TRANSFORMFIELD NAME="BATCH_ID"    DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="$$BATCH_ID"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="CUST_ID"     TOTRANSFORMATION="EXPR_CUST" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="CUST_NAME"   TOTRANSFORMATION="EXPR_CUST" TOFIELD="CUST_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="EMAIL"       TOTRANSFORMATION="EXPR_CUST" TOFIELD="EMAIL"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="PHONE"       TOTRANSFORMATION="EXPR_CUST" TOFIELD="PHONE"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="SEGMENT_CD"  TOTRANSFORMATION="EXPR_CUST" TOFIELD="SEGMENT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="KYC_STATUS"  TOTRANSFORMATION="EXPR_CUST" TOFIELD="KYC_STATUS"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="LAST_MOD_DT" TOTRANSFORMATION="EXPR_CUST" TOFIELD="LAST_MOD_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_CUST_DELTA" FROMFIELD="CREATED_DT"  TOTRANSFORMATION="EXPR_CUST" TOFIELD="CREATED_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="CUST_ID"     TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="CUST_NAME"   TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="CUST_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="EMAIL"       TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="EMAIL"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="PHONE"       TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="PHONE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="SEGMENT_CD"  TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="SEGMENT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="KYC_STATUS"  TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="KYC_STATUS"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="LAST_MOD_DT" TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="LAST_MOD_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="CREATED_DT"  TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="CREATED_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="LOAD_TS"     TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="LOAD_TS"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_CUST" FROMFIELD="BATCH_ID"    TOTRANSFORMATION="CUSTOMER_DIM" TOFIELD="BATCH_ID"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="CUSTOMER_DIM"/>
        <TARGETINSTANCE NAME="CUSTOMER_DIM" UPDATEOVERRIDE="" UPDATESTRATEGY="DD_INSERT,DD_UPDATE"/>
        <MAPPINGVARIABLE NAME="$$WATERMARK_FROM" DATATYPE="date" DEFAULTVALUE="1/1/1900 0:0:0"/>
        <MAPPINGVARIABLE NAME="$$BATCH_ID"       DATATYPE="string" DEFAULTVALUE=""/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
