<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="TXN_FACT_LOAD">
        <SOURCE NAME="TRANSACTIONS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="TXN_ID"       DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_ID"      DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="TXN_AMT"      DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <SOURCEFIELD NAME="TXN_DT"       DATATYPE="date"/>
          <SOURCEFIELD NAME="TXN_STATUS"   DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="CHANNEL_CD"   DATATYPE="varchar2" LENGTH="4"/>
          <SOURCEFIELD NAME="CREATED_DT"   DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="TXN_FACT" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="TXN_ID"            DATATYPE="number"  KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="CUST_ID"           DATATYPE="number"  NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="TXN_AMOUNT"        DATATYPE="number"  PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="TXN_DATE"          DATATYPE="date"/>
          <TARGETFIELD NAME="TXN_STATUS_DESC"   DATATYPE="varchar2" LENGTH="30"/>
          <TARGETFIELD NAME="CHANNEL_NAME"      DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="LOAD_TS"           DATATYPE="date"/>
          <TARGETFIELD NAME="IS_HIGH_VALUE"     DATATYPE="varchar2" LENGTH="1"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_TXN" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="TXN_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_AMT"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_DT"     DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_STATUS" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CHANNEL_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CREATED_DT" DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT * FROM TRANSACTIONS_SRC WHERE TXN_DT &gt;= SYSDATE - 30"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_TXN" TYPE="Expression">
          <TRANSFORMFIELD NAME="TXN_ID"          DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="TXN_ID"/>
          <TRANSFORMFIELD NAME="CUST_ID"         DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"/>
          <TRANSFORMFIELD NAME="TXN_AMOUNT"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(TXN_AMT, 0)"/>
          <TRANSFORMFIELD NAME="TXN_DATE"        DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="TO_DATE(TO_CHAR(TXN_DT,'YYYY-MM-DD'),'YYYY-MM-DD')"/>
          <TRANSFORMFIELD NAME="TXN_STATUS_DESC" DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="DECODE(TXN_STATUS,'APPR','APPROVED','DECL','DECLINED','PEND','PENDING','UNKNOWN')"/>
          <TRANSFORMFIELD NAME="CHANNEL_NAME"    DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="IIF(CHANNEL_CD='WEB','ONLINE',IIF(CHANNEL_CD='MOB','MOBILE','BRANCH'))"/>
          <TRANSFORMFIELD NAME="LOAD_TS"         DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="SYSDATE"/>
          <TRANSFORMFIELD NAME="IS_HIGH_VALUE"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="IIF(NVL(TXN_AMT,0) &gt; 10000,'Y','N')"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="TXN_ID"     TOTRANSFORMATION="EXPR_TXN"  TOFIELD="TXN_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="CUST_ID"    TOTRANSFORMATION="EXPR_TXN"  TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="TXN_AMT"    TOTRANSFORMATION="EXPR_TXN"  TOFIELD="TXN_AMOUNT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="TXN_DT"     TOTRANSFORMATION="EXPR_TXN"  TOFIELD="TXN_DATE"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="TXN_STATUS" TOTRANSFORMATION="EXPR_TXN"  TOFIELD="TXN_STATUS_DESC"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="CHANNEL_CD" TOTRANSFORMATION="EXPR_TXN"  TOFIELD="CHANNEL_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="CREATED_DT" TOTRANSFORMATION="EXPR_TXN"  TOFIELD="LOAD_TS"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN"  FROMFIELD="TXN_AMT"    TOTRANSFORMATION="EXPR_TXN"  TOFIELD="IS_HIGH_VALUE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="TXN_ID"          TOTRANSFORMATION="TXN_FACT" TOFIELD="TXN_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="CUST_ID"         TOTRANSFORMATION="TXN_FACT" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="TXN_AMOUNT"      TOTRANSFORMATION="TXN_FACT" TOFIELD="TXN_AMOUNT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="TXN_DATE"        TOTRANSFORMATION="TXN_FACT" TOFIELD="TXN_DATE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="TXN_STATUS_DESC" TOTRANSFORMATION="TXN_FACT" TOFIELD="TXN_STATUS_DESC"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="CHANNEL_NAME"    TOTRANSFORMATION="TXN_FACT" TOFIELD="CHANNEL_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="LOAD_TS"         TOTRANSFORMATION="TXN_FACT" TOFIELD="LOAD_TS"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_TXN" FROMFIELD="IS_HIGH_VALUE"   TOTRANSFORMATION="TXN_FACT" TOFIELD="IS_HIGH_VALUE"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="TXN_FACT"/>
        <MAPPINGVARIABLE NAME="$$LOAD_DT" DATATYPE="date" DEFAULTVALUE="1/1/1900 0:0:0"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
