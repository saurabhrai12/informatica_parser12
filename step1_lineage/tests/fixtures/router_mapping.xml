<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="RISK">
      <MAPPING NAME="ALERT_ROUTER_LOAD">
        <SOURCE NAME="ALERTS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="ALERT_ID"     DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="ALERT_TYPE"   DATATYPE="varchar2" LENGTH="20"  NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="RISK_SCORE"   DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <SOURCEFIELD NAME="ALERT_STATUS" DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="CUST_ID"      DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CREATED_DT"   DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="HIGH_RISK_ALERTS" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ALERT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY"/>
          <TARGETFIELD NAME="ALERT_TYPE" DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="RISK_SCORE" DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <TARGETFIELD NAME="CUST_ID"    DATATYPE="number"/>
        </TARGET>
        <TARGET NAME="MEDIUM_RISK_ALERTS" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ALERT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY"/>
          <TARGETFIELD NAME="ALERT_TYPE" DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="RISK_SCORE" DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <TARGETFIELD NAME="CUST_ID"    DATATYPE="number"/>
        </TARGET>
        <TARGET NAME="LOW_RISK_ALERTS" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ALERT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY"/>
          <TARGETFIELD NAME="ALERT_TYPE" DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="RISK_SCORE" DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <TARGETFIELD NAME="CUST_ID"    DATATYPE="number"/>
        </TARGET>
        <TARGET NAME="REJECTED_ALERTS" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ALERT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY"/>
          <TARGETFIELD NAME="ALERT_TYPE" DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="RISK_SCORE" DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <TARGETFIELD NAME="CUST_ID"    DATATYPE="number"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_ALERTS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="ALERT_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ALERT_TYPE"   DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="RISK_SCORE"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ALERT_STATUS" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"      DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CREATED_DT"   DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT * FROM ALERTS_SRC WHERE ALERT_STATUS != 'VOID'"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="RTR_RISK" TYPE="Router">
          <TRANSFORMFIELD NAME="ALERT_ID"   DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="ALERT_TYPE" DATATYPE="varchar2" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="RISK_SCORE" DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"    DATATYPE="number"   PORTTYPE="INPUT"/>
          <TABLEATTRIBUTE NAME="Group Name" VALUE="HIGH_RISK"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition" VALUE="RISK_SCORE &gt;= 80"/>
          <TABLEATTRIBUTE NAME="Group Name" VALUE="MEDIUM_RISK"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition" VALUE="RISK_SCORE &gt;= 40 AND RISK_SCORE &lt; 80"/>
          <TABLEATTRIBUTE NAME="Group Name" VALUE="LOW_RISK"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition" VALUE="RISK_SCORE &gt; 0 AND RISK_SCORE &lt; 40"/>
          <TABLEATTRIBUTE NAME="Group Name" VALUE="DEFAULT"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition" VALUE="TRUE"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_ALERTS"  FROMFIELD="ALERT_ID"   TOTRANSFORMATION="RTR_RISK" TOFIELD="ALERT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ALERTS"  FROMFIELD="ALERT_TYPE" TOTRANSFORMATION="RTR_RISK" TOFIELD="ALERT_TYPE"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ALERTS"  FROMFIELD="RISK_SCORE" TOTRANSFORMATION="RTR_RISK" TOFIELD="RISK_SCORE"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ALERTS"  FROMFIELD="CUST_ID"    TOTRANSFORMATION="RTR_RISK" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_ID"   TOTRANSFORMATION="HIGH_RISK_ALERTS"   TOFIELD="ALERT_ID"   FROMGROUP="HIGH_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_TYPE" TOTRANSFORMATION="HIGH_RISK_ALERTS"   TOFIELD="ALERT_TYPE" FROMGROUP="HIGH_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="RISK_SCORE" TOTRANSFORMATION="HIGH_RISK_ALERTS"   TOFIELD="RISK_SCORE" FROMGROUP="HIGH_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="CUST_ID"    TOTRANSFORMATION="HIGH_RISK_ALERTS"   TOFIELD="CUST_ID"    FROMGROUP="HIGH_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_ID"   TOTRANSFORMATION="MEDIUM_RISK_ALERTS" TOFIELD="ALERT_ID"   FROMGROUP="MEDIUM_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_TYPE" TOTRANSFORMATION="MEDIUM_RISK_ALERTS" TOFIELD="ALERT_TYPE" FROMGROUP="MEDIUM_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="RISK_SCORE" TOTRANSFORMATION="MEDIUM_RISK_ALERTS" TOFIELD="RISK_SCORE" FROMGROUP="MEDIUM_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="CUST_ID"    TOTRANSFORMATION="MEDIUM_RISK_ALERTS" TOFIELD="CUST_ID"    FROMGROUP="MEDIUM_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_ID"   TOTRANSFORMATION="LOW_RISK_ALERTS"    TOFIELD="ALERT_ID"   FROMGROUP="LOW_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_TYPE" TOTRANSFORMATION="LOW_RISK_ALERTS"    TOFIELD="ALERT_TYPE" FROMGROUP="LOW_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="RISK_SCORE" TOTRANSFORMATION="LOW_RISK_ALERTS"    TOFIELD="RISK_SCORE" FROMGROUP="LOW_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="CUST_ID"    TOTRANSFORMATION="LOW_RISK_ALERTS"    TOFIELD="CUST_ID"    FROMGROUP="LOW_RISK"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_ID"   TOTRANSFORMATION="REJECTED_ALERTS"    TOFIELD="ALERT_ID"   FROMGROUP="DEFAULT"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="ALERT_TYPE" TOTRANSFORMATION="REJECTED_ALERTS"    TOFIELD="ALERT_TYPE" FROMGROUP="DEFAULT"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="RISK_SCORE" TOTRANSFORMATION="REJECTED_ALERTS"    TOFIELD="RISK_SCORE" FROMGROUP="DEFAULT"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_RISK"   FROMFIELD="CUST_ID"    TOTRANSFORMATION="REJECTED_ALERTS"    TOFIELD="CUST_ID"    FROMGROUP="DEFAULT"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="HIGH_RISK_ALERTS"/>
        <TARGETLOADORDER ORDER="2" TARGETNAME="MEDIUM_RISK_ALERTS"/>
        <TARGETLOADORDER ORDER="3" TARGETNAME="LOW_RISK_ALERTS"/>
        <TARGETLOADORDER ORDER="4" TARGETNAME="REJECTED_ALERTS"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
