<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="PRODUCT_DIM_RELOAD">
        <SOURCE NAME="PRODUCTS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="PRODUCT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="PRODUCT_CD"   DATATYPE="varchar2" LENGTH="20"  NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="PRODUCT_NAME" DATATYPE="varchar2" LENGTH="200"/>
          <SOURCEFIELD NAME="CATEGORY_CD"  DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="SUB_CAT_CD"   DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="UNIT_PRICE"   DATATYPE="number"   PRECISION="12" SCALE="2"/>
          <SOURCEFIELD NAME="ACTIVE_FLG"   DATATYPE="varchar2" LENGTH="1"/>
          <SOURCEFIELD NAME="EFF_DT"       DATATYPE="date"/>
          <SOURCEFIELD NAME="EXP_DT"       DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="PRODUCT_DIM" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="PRODUCT_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="PRODUCT_CD"   DATATYPE="varchar2" LENGTH="20"  NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="PRODUCT_NAME" DATATYPE="varchar2" LENGTH="200"/>
          <TARGETFIELD NAME="CATEGORY_CD"  DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="SUB_CAT_CD"   DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="UNIT_PRICE"   DATATYPE="number"   PRECISION="12" SCALE="2"/>
          <TARGETFIELD NAME="ACTIVE_FLG"   DATATYPE="varchar2" LENGTH="1"/>
          <TARGETFIELD NAME="EFF_DT"       DATATYPE="date"/>
          <TARGETFIELD NAME="EXP_DT"       DATATYPE="date"/>
          <TARGETFIELD NAME="LOAD_TS"      DATATYPE="date"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_PRODUCTS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="PRODUCT_ID"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD"   DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="PRODUCT_NAME" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CATEGORY_CD"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="SUB_CAT_CD"   DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="UNIT_PRICE"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ACTIVE_FLG"   DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="EFF_DT"       DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="EXP_DT"       DATATYPE="date"     PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_PRODUCT" TYPE="Expression">
          <TRANSFORMFIELD NAME="PRODUCT_ID"   DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="PRODUCT_ID"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="PRODUCT_CD"/>
          <TRANSFORMFIELD NAME="PRODUCT_NAME" DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="UPPER(LTRIM(RTRIM(NVL(PRODUCT_NAME,'UNKNOWN'))))"/>
          <TRANSFORMFIELD NAME="CATEGORY_CD"  DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(CATEGORY_CD,'MISC')"/>
          <TRANSFORMFIELD NAME="SUB_CAT_CD"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(SUB_CAT_CD,'NA')"/>
          <TRANSFORMFIELD NAME="UNIT_PRICE"   DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(UNIT_PRICE,0)"/>
          <TRANSFORMFIELD NAME="ACTIVE_FLG"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(ACTIVE_FLG,'N')"/>
          <TRANSFORMFIELD NAME="EFF_DT"       DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(EFF_DT,TO_DATE('19000101','YYYYMMDD'))"/>
          <TRANSFORMFIELD NAME="EXP_DT"       DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(EXP_DT,TO_DATE('99991231','YYYYMMDD'))"/>
          <TRANSFORMFIELD NAME="LOAD_TS"      DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="SYSDATE"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="PRODUCT_ID"   TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="PRODUCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="PRODUCT_CD"   TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="PRODUCT_NAME" TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="PRODUCT_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="CATEGORY_CD"  TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="CATEGORY_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="SUB_CAT_CD"   TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="SUB_CAT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="UNIT_PRICE"   TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="UNIT_PRICE"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="ACTIVE_FLG"   TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="ACTIVE_FLG"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="EFF_DT"       TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="EFF_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_PRODUCTS" FROMFIELD="EXP_DT"       TOTRANSFORMATION="EXPR_PRODUCT" TOFIELD="EXP_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="PRODUCT_ID"   TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="PRODUCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="PRODUCT_CD"   TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="PRODUCT_NAME" TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="PRODUCT_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="CATEGORY_CD"  TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="CATEGORY_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="SUB_CAT_CD"   TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="SUB_CAT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="UNIT_PRICE"   TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="UNIT_PRICE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="ACTIVE_FLG"   TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="ACTIVE_FLG"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="EFF_DT"       TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="EFF_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="EXP_DT"       TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="EXP_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_PRODUCT" FROMFIELD="LOAD_TS"      TOTRANSFORMATION="PRODUCT_DIM" TOFIELD="LOAD_TS"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="PRODUCT_DIM"/>
        <TARGETINSTANCE NAME="PRODUCT_DIM" TRUNCATETARGET="YES" UPDATESTRATEGY="DD_INSERT"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
