<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="CUST_ENRICH_LOAD">
        <SOURCE NAME="ORDERS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="ORDER_ID"   DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_ID"    DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="PRODUCT_CD" DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="ORDER_AMT"  DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <SOURCEFIELD NAME="ORDER_DT"   DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="ORDERS_ENRICHED" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ORDER_ID"      DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="CUST_ID"       DATATYPE="number"   NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="PRODUCT_CD"    DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="ORDER_AMT"     DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="ORDER_DT"      DATATYPE="date"/>
          <TARGETFIELD NAME="CUST_SEGMENT"  DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="CUST_TIER"     DATATYPE="varchar2" LENGTH="5"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_ORDERS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="ORDER_ID"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ORDER_AMT"  DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ORDER_DT"   DATATYPE="date"     PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_CUST_SEGMENT" TYPE="Lookup Procedure">
          <TRANSFORMFIELD NAME="CUST_ID"       DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_SEGMENT"  DATATYPE="varchar2" PORTTYPE="OUTPUT" EXPRESSION=":LKP.LKP_CUST_SEGMENT(CUST_ID)"/>
          <TRANSFORMFIELD NAME="CUST_TIER"     DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Lookup table name" VALUE="CUSTOMER_MASTER"/>
          <TABLEATTRIBUTE NAME="Lookup condition"  VALUE="CUST_ID = CUST_ID"/>
          <TABLEATTRIBUTE NAME="Lookup policy if no row found" VALUE="Return no rows"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_CUST_DETAILS" TYPE="Lookup Procedure">
          <TRANSFORMFIELD NAME="CUST_ID"   DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_TIER" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Lookup table name" VALUE="CUSTOMER_TIER_REF"/>
          <TABLEATTRIBUTE NAME="Lookup condition"  VALUE="CUST_ID = CUST_ID AND ACTIVE_FLG = 'Y'"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="ORDER_ID"   TOTRANSFORMATION="ORDERS_ENRICHED"   TOFIELD="ORDER_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="CUST_ID"    TOTRANSFORMATION="ORDERS_ENRICHED"   TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="PRODUCT_CD" TOTRANSFORMATION="ORDERS_ENRICHED"   TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="ORDER_AMT"  TOTRANSFORMATION="ORDERS_ENRICHED"   TOFIELD="ORDER_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="ORDER_DT"   TOTRANSFORMATION="ORDERS_ENRICHED"   TOFIELD="ORDER_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="CUST_ID"    TOTRANSFORMATION="LKP_CUST_SEGMENT"  TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="CUST_ID"    TOTRANSFORMATION="LKP_CUST_DETAILS"  TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="LKP_CUST_SEGMENT" FROMFIELD="CUST_SEGMENT" TOTRANSFORMATION="ORDERS_ENRICHED" TOFIELD="CUST_SEGMENT"/>
        <CONNECTOR FROMTRANSFORMATION="LKP_CUST_DETAILS" FROMFIELD="CUST_TIER"    TOTRANSFORMATION="ORDERS_ENRICHED" TOFIELD="CUST_TIER"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="ORDERS_ENRICHED"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
