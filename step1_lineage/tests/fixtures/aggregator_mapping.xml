<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="DAILY_TXN_AGG">
        <SOURCE NAME="TRANSACTIONS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="TXN_ID"     DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_ID"    DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="TXN_AMT"    DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <SOURCEFIELD NAME="TXN_DT"     DATATYPE="date"/>
          <SOURCEFIELD NAME="CHANNEL_CD" DATATYPE="varchar2" LENGTH="4"/>
          <SOURCEFIELD NAME="RISK_FLAG"  DATATYPE="varchar2" LENGTH="1"/>
        </SOURCE>
        <TARGET NAME="DAILY_TXN_SUMMARY" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="CUST_ID"        DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="TXN_DT"         DATATYPE="date"     KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="CHANNEL_CD"     DATATYPE="varchar2" LENGTH="4" KEYTYPE="PRIMARY KEY"/>
          <TARGETFIELD NAME="TXN_COUNT"      DATATYPE="number"/>
          <TARGETFIELD NAME="TOTAL_AMT"      DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="AVG_AMT"        DATATYPE="number"   PRECISION="18" SCALE="4"/>
          <TARGETFIELD NAME="MAX_AMT"        DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="RISK_TXN_COUNT" DATATYPE="number"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_TXN_DAILY" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="TXN_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_AMT"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_DT"     DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CHANNEL_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="RISK_FLAG"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="AGG_DAILY" TYPE="Aggregator">
          <TRANSFORMFIELD NAME="CUST_ID"        DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"          GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="TXN_DT"         DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="TRUNC(TXN_DT)"    GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="CHANNEL_CD"     DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="CHANNEL_CD"       GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="TXN_COUNT"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="COUNT(TXN_ID)"    GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="TOTAL_AMT"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="SUM(NVL(TXN_AMT,0))" GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="AVG_AMT"        DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="AVG(NVL(TXN_AMT,0))" GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="MAX_AMT"        DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="MAX(TXN_AMT)"    GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="RISK_TXN_COUNT" DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="SUM(IIF(RISK_FLAG='Y',1,0))" GROUPBY="NO"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="TXN_ID"     TOTRANSFORMATION="AGG_DAILY" TOFIELD="TXN_COUNT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="CUST_ID"    TOTRANSFORMATION="AGG_DAILY" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="TXN_AMT"    TOTRANSFORMATION="AGG_DAILY" TOFIELD="TOTAL_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="TXN_AMT"    TOTRANSFORMATION="AGG_DAILY" TOFIELD="AVG_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="TXN_AMT"    TOTRANSFORMATION="AGG_DAILY" TOFIELD="MAX_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="TXN_DT"     TOTRANSFORMATION="AGG_DAILY" TOFIELD="TXN_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="CHANNEL_CD" TOTRANSFORMATION="AGG_DAILY" TOFIELD="CHANNEL_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_DAILY" FROMFIELD="RISK_FLAG"  TOTRANSFORMATION="AGG_DAILY" TOFIELD="RISK_TXN_COUNT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="CUST_ID"        TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="TXN_DT"         TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="TXN_DT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="CHANNEL_CD"     TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="CHANNEL_CD"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="TXN_COUNT"      TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="TXN_COUNT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="TOTAL_AMT"      TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="TOTAL_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="AVG_AMT"        TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="AVG_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="MAX_AMT"        TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="MAX_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_DAILY" FROMFIELD="RISK_TXN_COUNT" TOTRANSFORMATION="DAILY_TXN_SUMMARY" TOFIELD="RISK_TXN_COUNT"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="DAILY_TXN_SUMMARY"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
