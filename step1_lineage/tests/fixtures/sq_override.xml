<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="AUDIT">
      <MAPPING NAME="AUDIT_TRAIL_EXTRACT">
        <SOURCE NAME="AUDIT_LOG_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="LOG_ID"        DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="TABLE_NAME"    DATATYPE="varchar2" LENGTH="60"/>
          <SOURCEFIELD NAME="OPERATION"     DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="CHANGED_BY"    DATATYPE="varchar2" LENGTH="50"/>
          <SOURCEFIELD NAME="CHANGE_DT"     DATATYPE="date"/>
          <SOURCEFIELD NAME="OLD_VALUES"    DATATYPE="clob"/>
          <SOURCEFIELD NAME="NEW_VALUES"    DATATYPE="clob"/>
          <SOURCEFIELD NAME="SESSION_ID"    DATATYPE="number"/>
        </SOURCE>
        <TARGET NAME="AUDIT_TRAIL" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="LOG_ID"         DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="TABLE_NAME"     DATATYPE="varchar2" LENGTH="60"/>
          <TARGETFIELD NAME="OPERATION"      DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="CHANGED_BY"     DATATYPE="varchar2" LENGTH="50"/>
          <TARGETFIELD NAME="CHANGE_DT"      DATATYPE="date"/>
          <TARGETFIELD NAME="OLD_VALUES"     DATATYPE="varchar2" LENGTH="16777216"/>
          <TARGETFIELD NAME="NEW_VALUES"     DATATYPE="varchar2" LENGTH="16777216"/>
          <TARGETFIELD NAME="SESSION_ID"     DATATYPE="number"/>
          <TARGETFIELD NAME="DAYS_SINCE_CHG" DATATYPE="number"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_AUDIT" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="LOG_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TABLE_NAME" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="OPERATION"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CHANGED_BY" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CHANGE_DT"  DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="OLD_VALUES" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="NEW_VALUES" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="SESSION_ID" DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT AL.LOG_ID, AL.TABLE_NAME, AL.OPERATION,&#10;       AL.CHANGED_BY, AL.CHANGE_DT,&#10;       DBMS_LOB.SUBSTR(AL.OLD_VALUES, 4000, 1) AS OLD_VALUES,&#10;       DBMS_LOB.SUBSTR(AL.NEW_VALUES, 4000, 1) AS NEW_VALUES,&#10;       AL.SESSION_ID&#10;FROM   AUDIT_LOG_SRC AL&#10;WHERE  AL.CHANGE_DT &gt;= SYSDATE - 90&#10;AND    AL.TABLE_NAME IN ('CUSTOMER','ORDERS','TRANSACTIONS')&#10;ORDER  BY AL.CHANGE_DT ASC"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_AUDIT" TYPE="Expression">
          <TRANSFORMFIELD NAME="LOG_ID"         DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="LOG_ID"/>
          <TRANSFORMFIELD NAME="TABLE_NAME"     DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="TABLE_NAME"/>
          <TRANSFORMFIELD NAME="OPERATION"      DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="UPPER(OPERATION)"/>
          <TRANSFORMFIELD NAME="CHANGED_BY"     DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="UPPER(NVL(CHANGED_BY,'SYSTEM'))"/>
          <TRANSFORMFIELD NAME="CHANGE_DT"      DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="CHANGE_DT"/>
          <TRANSFORMFIELD NAME="OLD_VALUES"     DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(OLD_VALUES,'N/A')"/>
          <TRANSFORMFIELD NAME="NEW_VALUES"     DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(NEW_VALUES,'N/A')"/>
          <TRANSFORMFIELD NAME="SESSION_ID"     DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="SESSION_ID"/>
          <TRANSFORMFIELD NAME="DAYS_SINCE_CHG" DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="DATE_DIFF(SYSDATE,CHANGE_DT,'DD')"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="LOG_ID"     TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="LOG_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="TABLE_NAME" TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="TABLE_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="OPERATION"  TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="OPERATION"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="CHANGED_BY" TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="CHANGED_BY"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="CHANGE_DT"  TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="CHANGE_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="OLD_VALUES" TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="OLD_VALUES"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="NEW_VALUES" TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="NEW_VALUES"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="SESSION_ID" TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="SESSION_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_AUDIT" FROMFIELD="CHANGE_DT"  TOTRANSFORMATION="EXPR_AUDIT" TOFIELD="DAYS_SINCE_CHG"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="LOG_ID"         TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="LOG_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="TABLE_NAME"     TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="TABLE_NAME"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="OPERATION"      TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="OPERATION"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="CHANGED_BY"     TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="CHANGED_BY"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="CHANGE_DT"      TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="CHANGE_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="OLD_VALUES"     TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="OLD_VALUES"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="NEW_VALUES"     TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="NEW_VALUES"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="SESSION_ID"     TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="SESSION_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_AUDIT" FROMFIELD="DAYS_SINCE_CHG" TOTRANSFORMATION="AUDIT_TRAIL" TOFIELD="DAYS_SINCE_CHG"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="AUDIT_TRAIL"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
