<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="RISK">
      <MAPPING NAME="FRAUD_ALERT_PIPELINE">
        <SOURCE NAME="TXN_RAW_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="TXN_ID"       DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="ACCT_ID"      DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_ID"      DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="TXN_AMT"      DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <SOURCEFIELD NAME="TXN_DT"       DATATYPE="date"/>
          <SOURCEFIELD NAME="MERCHANT_CD"  DATATYPE="varchar2" LENGTH="20"/>
          <SOURCEFIELD NAME="CHANNEL_CD"   DATATYPE="varchar2" LENGTH="4"/>
          <SOURCEFIELD NAME="COUNTRY_CD"   DATATYPE="varchar2" LENGTH="3"/>
          <SOURCEFIELD NAME="CREATED_DT"   DATATYPE="date"/>
        </SOURCE>
        <TARGET NAME="FRAUD_ALERTS_FCT" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ALERT_SK"       DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="TXN_ID"         DATATYPE="number"   NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="ACCT_ID"        DATATYPE="number"/>
          <TARGETFIELD NAME="CUST_ID"        DATATYPE="number"/>
          <TARGETFIELD NAME="TXN_AMT"        DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="TXN_DT"         DATATYPE="date"/>
          <TARGETFIELD NAME="TXN_AMT_BAND"   DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="FRAUD_SCORE"    DATATYPE="number"   PRECISION="5" SCALE="2"/>
          <TARGETFIELD NAME="FRAUD_REASON"   DATATYPE="varchar2" LENGTH="200"/>
          <TARGETFIELD NAME="CUST_SEGMENT"   DATATYPE="varchar2" LENGTH="20"/>
          <TARGETFIELD NAME="ACCT_RISK_TIER" DATATYPE="varchar2" LENGTH="5"/>
          <TARGETFIELD NAME="LOAD_TS"        DATATYPE="date"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_TXN_RAW" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="TXN_ID"      DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ACCT_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_AMT"     DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="TXN_DT"      DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="MERCHANT_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CHANNEL_CD"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="COUNTRY_CD"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CREATED_DT"  DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT * FROM TXN_RAW_SRC WHERE TXN_DT &gt;= $$WATERMARK_FROM AND TXN_DT &lt; $$WATERMARK_TO"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_BAND" TYPE="Expression">
          <TRANSFORMFIELD NAME="TXN_ID"        DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="TXN_ID"/>
          <TRANSFORMFIELD NAME="ACCT_ID"       DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="ACCT_ID"/>
          <TRANSFORMFIELD NAME="CUST_ID"       DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"/>
          <TRANSFORMFIELD NAME="TXN_AMT"       DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="TXN_AMT"/>
          <TRANSFORMFIELD NAME="TXN_DT"        DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="TRUNC(TXN_DT)"/>
          <TRANSFORMFIELD NAME="MERCHANT_CD"   DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="MERCHANT_CD"/>
          <TRANSFORMFIELD NAME="CHANNEL_CD"    DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="CHANNEL_CD"/>
          <TRANSFORMFIELD NAME="COUNTRY_CD"    DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="COUNTRY_CD"/>
          <TRANSFORMFIELD NAME="TXN_AMT_BAND"  DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="IIF(NVL(TXN_AMT,0)&gt;=100000,'MEGA',IIF(NVL(TXN_AMT,0)&gt;=10000,'HIGH',IIF(NVL(TXN_AMT,0)&gt;=1000,'MED','LOW')))"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_CUST_SEG" TYPE="Lookup Procedure">
          <TRANSFORMFIELD NAME="CUST_ID"       DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_SEGMENT"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Lookup table name" VALUE="CUSTOMER_MASTER"/>
          <TABLEATTRIBUTE NAME="Lookup condition"  VALUE="CUST_ID = CUST_ID"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_ACCT_RISK" TYPE="Lookup Procedure">
          <TRANSFORMFIELD NAME="ACCT_ID"        DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="ACCT_RISK_TIER"  DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TABLEATTRIBUTE NAME="Lookup table name" VALUE="ACCOUNT_RISK_PROFILE"/>
          <TABLEATTRIBUTE NAME="Lookup condition"  VALUE="ACCT_ID = ACCT_ID"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="AGG_FRAUD_SCORE" TYPE="Aggregator">
          <TRANSFORMFIELD NAME="TXN_ID"       DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="TXN_ID"       GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="ACCT_ID"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="ACCT_ID"      GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="CUST_ID"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"      GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="TXN_AMT"      DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="MAX(TXN_AMT)" GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="TXN_DT"       DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="MAX(TXN_DT)"  GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="TXN_AMT_BAND" DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="TXN_AMT_BAND" GROUPBY="YES"/>
          <TRANSFORMFIELD NAME="FRAUD_SCORE"  DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="SUM(IIF(CHANNEL_CD='INT',30,0)+IIF(COUNTRY_CD!='US',25,0)+IIF(TXN_AMT_BAND='MEGA',45,IIF(TXN_AMT_BAND='HIGH',20,0)))" GROUPBY="NO"/>
          <TRANSFORMFIELD NAME="FRAUD_REASON" DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="IIF(FRAUD_SCORE&gt;=80,'HIGH_RISK_COMPOSITE',IIF(FRAUD_SCORE&gt;=40,'MEDIUM_RISK','LOW_RISK'))" GROUPBY="NO"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="RTR_FRAUD" TYPE="Router">
          <TRANSFORMFIELD NAME="ALERT_SK"       DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="TXN_ID"         DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="ACCT_ID"        DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"        DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="TXN_AMT"        DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="TXN_DT"         DATATYPE="date"     PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="TXN_AMT_BAND"   DATATYPE="varchar2" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="FRAUD_SCORE"    DATATYPE="number"   PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="FRAUD_REASON"   DATATYPE="varchar2" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="CUST_SEGMENT"   DATATYPE="varchar2" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="ACCT_RISK_TIER" DATATYPE="varchar2" PORTTYPE="INPUT"/>
          <TRANSFORMFIELD NAME="LOAD_TS"        DATATYPE="date"     PORTTYPE="INPUT"/>
          <TABLEATTRIBUTE NAME="Group Name"              VALUE="HIGH_FRAUD"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition"  VALUE="FRAUD_SCORE &gt;= 80"/>
          <TABLEATTRIBUTE NAME="Group Name"              VALUE="DEFAULT"/>
          <TABLEATTRIBUTE NAME="Group Filter Condition"  VALUE="TRUE"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="TXN_ID"      TOTRANSFORMATION="EXPR_BAND"     TOFIELD="TXN_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="ACCT_ID"     TOTRANSFORMATION="EXPR_BAND"     TOFIELD="ACCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="CUST_ID"     TOTRANSFORMATION="EXPR_BAND"     TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="TXN_AMT"     TOTRANSFORMATION="EXPR_BAND"     TOFIELD="TXN_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="TXN_DT"      TOTRANSFORMATION="EXPR_BAND"     TOFIELD="TXN_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="MERCHANT_CD" TOTRANSFORMATION="EXPR_BAND"     TOFIELD="MERCHANT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="CHANNEL_CD"  TOTRANSFORMATION="EXPR_BAND"     TOFIELD="CHANNEL_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_TXN_RAW"    FROMFIELD="COUNTRY_CD"  TOTRANSFORMATION="EXPR_BAND"     TOFIELD="COUNTRY_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="CUST_ID"     TOTRANSFORMATION="LKP_CUST_SEG"  TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="ACCT_ID"     TOTRANSFORMATION="LKP_ACCT_RISK" TOFIELD="ACCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="TXN_ID"      TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="TXN_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="ACCT_ID"     TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="ACCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="CUST_ID"     TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="TXN_AMT"     TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="TXN_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="TXN_DT"      TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="TXN_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="TXN_AMT_BAND" TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="TXN_AMT_BAND"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="CHANNEL_CD"  TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="FRAUD_SCORE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_BAND"     FROMFIELD="COUNTRY_CD"  TOTRANSFORMATION="AGG_FRAUD_SCORE" TOFIELD="FRAUD_REASON"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="TXN_ID"        TOTRANSFORMATION="RTR_FRAUD" TOFIELD="TXN_ID"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="ACCT_ID"       TOTRANSFORMATION="RTR_FRAUD" TOFIELD="ACCT_ID"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="CUST_ID"       TOTRANSFORMATION="RTR_FRAUD" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="TXN_AMT"       TOTRANSFORMATION="RTR_FRAUD" TOFIELD="TXN_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="TXN_DT"        TOTRANSFORMATION="RTR_FRAUD" TOFIELD="TXN_DT"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="TXN_AMT_BAND"  TOTRANSFORMATION="RTR_FRAUD" TOFIELD="TXN_AMT_BAND"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="FRAUD_SCORE"   TOTRANSFORMATION="RTR_FRAUD" TOFIELD="FRAUD_SCORE"/>
        <CONNECTOR FROMTRANSFORMATION="AGG_FRAUD_SCORE" FROMFIELD="FRAUD_REASON"  TOTRANSFORMATION="RTR_FRAUD" TOFIELD="FRAUD_REASON"/>
        <CONNECTOR FROMTRANSFORMATION="LKP_CUST_SEG"   FROMFIELD="CUST_SEGMENT"  TOTRANSFORMATION="RTR_FRAUD" TOFIELD="CUST_SEGMENT"/>
        <CONNECTOR FROMTRANSFORMATION="LKP_ACCT_RISK"  FROMFIELD="ACCT_RISK_TIER" TOTRANSFORMATION="RTR_FRAUD" TOFIELD="ACCT_RISK_TIER"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="TXN_ID"         TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="TXN_ID"         FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="ACCT_ID"        TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="ACCT_ID"        FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="CUST_ID"        TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="CUST_ID"        FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="TXN_AMT"        TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="TXN_AMT"        FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="TXN_DT"         TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="TXN_DT"         FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="TXN_AMT_BAND"   TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="TXN_AMT_BAND"   FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="FRAUD_SCORE"    TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="FRAUD_SCORE"    FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="FRAUD_REASON"   TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="FRAUD_REASON"   FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="CUST_SEGMENT"   TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="CUST_SEGMENT"   FROMGROUP="HIGH_FRAUD"/>
        <CONNECTOR FROMTRANSFORMATION="RTR_FRAUD" FROMFIELD="ACCT_RISK_TIER" TOTRANSFORMATION="FRAUD_ALERTS_FCT" TOFIELD="ACCT_RISK_TIER" FROMGROUP="HIGH_FRAUD"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="FRAUD_ALERTS_FCT"/>
        <TARGETINSTANCE NAME="FRAUD_ALERTS_FCT" UPDATESTRATEGY="DD_INSERT,DD_UPDATE"/>
        <MAPPINGVARIABLE NAME="$$WATERMARK_FROM" DATATYPE="date" DEFAULTVALUE="1/1/1900 0:0:0"/>
        <MAPPINGVARIABLE NAME="$$WATERMARK_TO"   DATATYPE="date" DEFAULTVALUE="12/31/9999 23:59:59"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
