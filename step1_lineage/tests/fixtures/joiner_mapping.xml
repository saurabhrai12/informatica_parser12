<?xml version="1.0"?>
<POWERMART>
  <REPOSITORY NAME="DWH_REP">
    <FOLDER NAME="FINANCE">
      <MAPPING NAME="ORDER_DETAIL_JOIN">
        <SOURCE NAME="ORDERS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="ORDER_ID"    DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="CUST_ID"     DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="ORDER_DT"    DATATYPE="date"/>
          <SOURCEFIELD NAME="STATUS_CD"   DATATYPE="varchar2" LENGTH="5"/>
        </SOURCE>
        <SOURCE NAME="ORDER_ITEMS_SRC" DATABASETYPE="ORACLE" DBDNAME="ORA_DWH">
          <SOURCEFIELD NAME="ITEM_ID"     DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="ORDER_ID"    DATATYPE="number"   NULLABLE="NOT NULL"/>
          <SOURCEFIELD NAME="PRODUCT_CD"  DATATYPE="varchar2" LENGTH="10"/>
          <SOURCEFIELD NAME="QTY"         DATATYPE="number"/>
          <SOURCEFIELD NAME="UNIT_PRICE"  DATATYPE="number"   PRECISION="12" SCALE="2"/>
        </SOURCE>
        <TARGET NAME="ORDER_DETAIL_FACT" DATABASETYPE="SNOWFLAKE" DBDNAME="PROD_DB">
          <TARGETFIELD NAME="ITEM_ID"     DATATYPE="number"   KEYTYPE="PRIMARY KEY" NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="ORDER_ID"    DATATYPE="number"   NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="CUST_ID"     DATATYPE="number"   NULLABLE="NOT NULL"/>
          <TARGETFIELD NAME="PRODUCT_CD"  DATATYPE="varchar2" LENGTH="10"/>
          <TARGETFIELD NAME="QTY"         DATATYPE="number"/>
          <TARGETFIELD NAME="UNIT_PRICE"  DATATYPE="number"   PRECISION="12" SCALE="2"/>
          <TARGETFIELD NAME="LINE_AMT"    DATATYPE="number"   PRECISION="18" SCALE="2"/>
          <TARGETFIELD NAME="ORDER_DT"    DATATYPE="date"/>
          <TARGETFIELD NAME="STATUS_CD"   DATATYPE="varchar2" LENGTH="5"/>
        </TARGET>
        <TRANSFORMATION NAME="SQ_ORDERS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="ORDER_ID"  DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="CUST_ID"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ORDER_DT"  DATATYPE="date"     PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="STATUS_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="SQ_ORDER_ITEMS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="ITEM_ID"    DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="ORDER_ID"   DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD" DATATYPE="varchar2" PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="QTY"        DATATYPE="number"   PORTTYPE="OUTPUT"/>
          <TRANSFORMFIELD NAME="UNIT_PRICE" DATATYPE="number"   PORTTYPE="OUTPUT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="JNR_ORDER_DETAIL" TYPE="Joiner">
          <TRANSFORMFIELD NAME="ORDER_ID_M"  DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="DETAIL"/>
          <TRANSFORMFIELD NAME="CUST_ID"     DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="DETAIL"/>
          <TRANSFORMFIELD NAME="ORDER_DT"    DATATYPE="date"     PORTTYPE="INPUT"        MASTERDETAIL="DETAIL"/>
          <TRANSFORMFIELD NAME="STATUS_CD"   DATATYPE="varchar2" PORTTYPE="INPUT"        MASTERDETAIL="DETAIL"/>
          <TRANSFORMFIELD NAME="ITEM_ID"     DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="MASTER"/>
          <TRANSFORMFIELD NAME="ORDER_ID_D"  DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="MASTER"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD"  DATATYPE="varchar2" PORTTYPE="INPUT"        MASTERDETAIL="MASTER"/>
          <TRANSFORMFIELD NAME="QTY"         DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="MASTER"/>
          <TRANSFORMFIELD NAME="UNIT_PRICE"  DATATYPE="number"   PORTTYPE="INPUT"        MASTERDETAIL="MASTER"/>
          <TABLEATTRIBUTE NAME="Join Condition"  VALUE="ORDER_ID_M = ORDER_ID_D"/>
          <TABLEATTRIBUTE NAME="Join Type"       VALUE="Normal Join"/>
          <TABLEATTRIBUTE NAME="Master Source"   VALUE="SQ_ORDER_ITEMS"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXPR_LINE_AMT" TYPE="Expression">
          <TRANSFORMFIELD NAME="ITEM_ID"    DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="ITEM_ID"/>
          <TRANSFORMFIELD NAME="ORDER_ID"   DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="ORDER_ID_M"/>
          <TRANSFORMFIELD NAME="CUST_ID"    DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="CUST_ID"/>
          <TRANSFORMFIELD NAME="PRODUCT_CD" DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="PRODUCT_CD"/>
          <TRANSFORMFIELD NAME="QTY"        DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="QTY"/>
          <TRANSFORMFIELD NAME="UNIT_PRICE" DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="UNIT_PRICE"/>
          <TRANSFORMFIELD NAME="LINE_AMT"   DATATYPE="number"   PORTTYPE="INPUT/OUTPUT" EXPRESSION="NVL(QTY,0) * NVL(UNIT_PRICE,0)"/>
          <TRANSFORMFIELD NAME="ORDER_DT"   DATATYPE="date"     PORTTYPE="INPUT/OUTPUT" EXPRESSION="ORDER_DT"/>
          <TRANSFORMFIELD NAME="STATUS_CD"  DATATYPE="varchar2" PORTTYPE="INPUT/OUTPUT" EXPRESSION="STATUS_CD"/>
        </TRANSFORMATION>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="ORDER_ID"  TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="ORDER_ID_M"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="CUST_ID"   TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="ORDER_DT"  TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="ORDER_DT"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDERS"       FROMFIELD="STATUS_CD" TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="STATUS_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDER_ITEMS"  FROMFIELD="ITEM_ID"    TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="ITEM_ID"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDER_ITEMS"  FROMFIELD="ORDER_ID"   TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="ORDER_ID_D"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDER_ITEMS"  FROMFIELD="PRODUCT_CD" TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDER_ITEMS"  FROMFIELD="QTY"        TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="QTY"/>
        <CONNECTOR FROMTRANSFORMATION="SQ_ORDER_ITEMS"  FROMFIELD="UNIT_PRICE" TOTRANSFORMATION="JNR_ORDER_DETAIL" TOFIELD="UNIT_PRICE"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="ITEM_ID"    TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="ITEM_ID"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="ORDER_ID_M" TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="ORDER_ID"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="CUST_ID"    TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="PRODUCT_CD" TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="QTY"        TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="QTY"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="UNIT_PRICE" TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="UNIT_PRICE"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="QTY"        TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="LINE_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="ORDER_DT"   TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="ORDER_DT"/>
        <CONNECTOR FROMTRANSFORMATION="JNR_ORDER_DETAIL" FROMFIELD="STATUS_CD"  TOTRANSFORMATION="EXPR_LINE_AMT" TOFIELD="STATUS_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="ITEM_ID"    TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="ITEM_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="ORDER_ID"   TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="ORDER_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="CUST_ID"    TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="CUST_ID"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="PRODUCT_CD" TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="PRODUCT_CD"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="QTY"        TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="QTY"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="UNIT_PRICE" TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="UNIT_PRICE"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="LINE_AMT"   TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="LINE_AMT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="ORDER_DT"   TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="ORDER_DT"/>
        <CONNECTOR FROMTRANSFORMATION="EXPR_LINE_AMT" FROMFIELD="STATUS_CD"  TOTRANSFORMATION="ORDER_DETAIL_FACT" TOFIELD="STATUS_CD"/>
        <TARGETLOADORDER ORDER="1" TARGETNAME="ORDER_DETAIL_FACT"/>
      </MAPPING>
    </FOLDER>
  </REPOSITORY>
</POWERMART>
