snowflake:
  account: HUBBXYZ-XA96647
  user: ""
  password: ""
  role: SYSADMIN
  warehouse: COMPUTE_WH
  database: PROD_DB
  target_schema: CORTEX_CHAT_APP
  source_schema: RAW_LAYER

oracle:
  dsn: ""
  user: ""
  password: ""

migration:
  proc_prefix: SP_
  audit_table: PROD_DB.CORTEX_CHAT_APP.MIGRATION_AUDIT_LOG
  error_table: PROD_DB.CORTEX_CHAT_APP.MIGRATION_ERROR_LOG
  column_renames: {}   # informatica_target_col: snowflake_col

cortex_llm:
  enabled: false           # set true to enable Strategy 15 LLM column matching
  model: mistral-7b        # Cortex model: mistral-7b | llama3-8b | mixtral-8x7b | llama3-70b
  top_n_candidates: 8      # max Snowflake candidates sent to LLM per Oracle column
  solo_cap: 0.82           # max confidence for a Cortex-only match (no rule-based corroboration)
  # Note: requires Snowflake account with Cortex enabled and CORTEX_USER privilege.
  # Snowflake function: SELECT SNOWFLAKE.CORTEX.COMPLETE('<model>', '<prompt>') AS response
  # Cost: ~$0.002 per 1K input tokens (mistral-7b); batch all columns per mapping call.
